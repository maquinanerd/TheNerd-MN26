## Gemini API keys (one or more). Values must start with AIza...
GEMINI_KEY_1=
GEMINI_KEY_2=

## Gemini model selection
GEMINI_MODEL_ID=gemini-2.5-flash-lite
AI_MODEL=gemini-2.5-flash-lite

## WordPress credentials
WORDPRESS_URL=
WORDPRESS_USER=
WORDPRESS_PASSWORD=

## Dashboard / logging
SECRET_KEY=
LOG_LEVEL=INFO

## Scheduler
CHECK_INTERVAL_MINUTES=15
MAX_ARTICLES_PER_FEED=3
PER_ARTICLE_DELAY_SECONDS=8
PER_FEED_DELAY_SECONDS=15
CLEANUP_AFTER_HOURS=72

## Pipeline
IMAGES_MODE=hotlink
PUBLISHER_LOGO_URL=
MAX_PER_FEED_CYCLE=3
MAX_PER_CYCLE=10
ARTICLE_SLEEP_S=120
BETWEEN_BATCH_DELAY_S=30
BETWEEN_PUBLISH_DELAY_S=30
FEED_STAGGER_S=45

## AI backoff / rate limits
AI_MIN_INTERVAL_S=6
BACKOFF_BASE_S=20
BACKOFF_MAX_S=300

## TMDB (optional)
TMDB_ENABLED=false
TMDB_API_KEY=
TMDB_ACCESS_TOKEN=
TMDB_MAX_ENRICHMENTS=3
TMDB_EXTRACT_TRENDING=false
TMDB_EXTRACT_UPCOMING=false
