# ====================================================================
# CONFIGURAÇÃO THE MOVIE DATABASE (TMDb)
# ====================================================================
# Obter chave gratuita em: https://www.themoviedb.org/settings/api

# Habilita integração com TMDb
TMDB_ENABLED=false

# Chave de API v3 da TMDb
TMDB_API_KEY=sua_chave_aqui

# Máximo de filmes/séries a enriquecer por artigo
TMDB_MAX_ENRICHMENTS=3

# Extrair filmes em tendência para criar widgets adicionais
TMDB_EXTRACT_TRENDING=false

# Extrair próximos lançamentos
TMDB_EXTRACT_UPCOMING=false
